# SAP ADT connection settings (for live source fetching)
# Copy this file to .env and fill in your values.
#
# Without these credentials the server runs in cache-only mode
# and can still serve previously fetched objects.

SAP_BASE_URL=https://your-sap-system.sap.corp
SAP_USERNAME=your_user
SAP_PASSWORD=your_password
# SAP_VERIFY_SSL=false
# SAP_CLIENT=001

# LLM proxy settings (for AI-powered code review, test generation, and explanations)
# Without these, the AI tools will be unavailable but static analysis still works.
# LLM_PROXY_URL=http://localhost:6655/litellm/v1/chat/completions
# LLM_API_KEY=your_api_key
# LLM_MODEL=anthropic--claude-4.6-opus
