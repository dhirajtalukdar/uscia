# SAP S/4HANA OData Connection
# Option A: Direct connection
S4_ODATA_HOST=""
S4_ODATA_USER=""
S4_ODATA_PASSWORD=""
S4_ODATA_CLIENT=""
# Option B: BTP Destination (via Cloud Connector, requires connectivity + destination service bindings)
# S4_ODATA_DESTINATION=""
# S4_ODATA_USER=""        # fallback if destination has NoAuthentication
# S4_ODATA_PASSWORD=""    # fallback if destination has NoAuthentication
# S4_ODATA_CLIENT=""      # fallback if destination has no sap-client property

# SAP S/4HANA HANA SQL Connection
# Option A: Direct connection
S4_SQL_HOST=""
S4_SQL_PORT=""
# Option B: BTP Destination (via Cloud Connector, requires connectivity + destination service bindings)
# S4_SQL_DESTINATION=""

# Always required for SQL
S4_SQL_USER=""
S4_SQL_PASSWORD=""

# Debug logging (Cloud Connector, BTP services, SQL tunnel)
# S4_DEBUG=true

# Server
# PORT=8080
